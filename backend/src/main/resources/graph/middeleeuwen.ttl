# Atlas chapter: Keizerstad — Verhalen migration.
# 18 segments across 3 threads: Van palts tot burcht (6), De stad aan de Waal (9),
# Stad van naam (3).
@prefix nmg:    <https://nijmegenkaart.nl/ns#> .
@prefix id:     <https://nijmegenkaart.nl/id/> .
@prefix schema: <http://schema.org/> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

############################  STORY  ############################
id:story_keizerstad a nmg:Story ;
    rdfs:label "Keizerstad"@nl ;
    nmg:introText "Op de Romeinse resten bouwde Karel de Grote een palts; eeuwenlang hielden keizers er rijksdagen. In de luwte van het Valkhof groeit aan de Waal de middeleeuwse stad — met stadsrechten, de Sint-Steven en, vanaf 1402, de Hanze."@nl ;
    nmg:eraLabel "Middeleeuwen"@nl ;
    nmg:representativeYear "1557"^^xsd:gYear ;
    nmg:tag "middeleeuwen" ;
    nmg:storyOrder 2 ;
    nmg:hasThread id:thread_vmk_palts , id:thread_vmk_stad , id:thread_vmk_naam .

############################  THREADS (verhaallijnen)  ############################
id:thread_vmk_palts a nmg:Thread ; rdfs:label "Van palts tot burcht"@nl ; nmg:order 1 ;
    nmg:hasSegment id:seg_vmk_1 , id:seg_vmk_2 , id:seg_vmk_3 , id:seg_vmk_4 ,
                    id:seg_vmk_5 , id:seg_vmk_6 .
id:thread_vmk_stad a nmg:Thread ; rdfs:label "De stad aan de Waal"@nl ; nmg:order 2 ;
    nmg:hasSegment id:seg_vmk_7 , id:seg_vmk_8 , id:seg_vmk_9 , id:seg_vmk_10 ,
                    id:seg_vmk_11 , id:seg_vmk_12 , id:seg_vmk_13 , id:seg_vmk_14 .
id:thread_vmk_naam a nmg:Thread ; rdfs:label "Stad van naam"@nl ; nmg:order 3 ;
    nmg:hasSegment id:seg_vmk_15 , id:seg_vmk_16 , id:seg_vmk_17 .

# --- Thread 1: Van palts tot burcht ---

# 1. Franken op het Valkhof
id:seg_vmk_1 a nmg:Segment ; nmg:order 1 ; nmg:tickLabel "Franken op het Valkhof" ;
    nmg:mapState id:map_vmk_1 ; nmg:hasBlock id:block_vmk_1_1 , id:block_vmk_1_2 .
id:map_vmk_1 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ;
    nmg:focusPlace id:valkhof .
id:block_vmk_1_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "Anders dan lang gedacht bleef het Valkhof bewoond. Het oude castellum bood onderdak aan de opkomende Frankische elite, en vlakbij lag een uitgestrekt Merovingisch grafveld met duizenden graven."@nl .
id:block_vmk_1_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_franken .

# 2. De palts van Karel de Grote
id:seg_vmk_2 a nmg:Segment ; nmg:order 2 ; nmg:tickLabel "De palts van Karel de Grote" ;
    nmg:mapState id:map_vmk_2 ; nmg:hasBlock id:block_vmk_2_1 , id:block_vmk_2_2 .
id:map_vmk_2 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ;
    nmg:focusPlace id:valkhof .
id:block_vmk_2_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "In 777 bouwde Karel de Grote een palts op het Valkhof, deels met hergebruikte Romeinse steen. Nijmegen — toen Numaga — werd een keizerlijke verblijfplaats waar Karel meermaals verbleef, onder meer met Pasen."@nl .
id:block_vmk_2_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_palts .

# 3. Vikingen plunderen de palts (pin + arrows)
id:seg_vmk_3 a nmg:Segment ; nmg:order 3 ; nmg:tickLabel "Vikingen plunderen de palts" ;
    nmg:mapState id:map_vmk_3 ; nmg:hasBlock id:block_vmk_3_1 , id:block_vmk_3_2 .
id:map_vmk_3 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ;
    nmg:focusPlace id:valkhof ;
    nmg:arrow id:arrow_vmk_3 .
id:arrow_vmk_3 a nmg:Arrow ; nmg:arrowFrom id:grote_markt ; nmg:arrowTo id:valkhof ;
    nmg:arrowLabel "Noormannen" ; nmg:arrowCurve 0.22 .
id:block_vmk_3_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "De Karolingische palts was een begeerd doelwit. Over de Waal voeren de Noormannen stroomopwaarts naar Nijmegen: in 838 vond de eerste overval plaats, in 880 belegerden en bezetten ze het Valkhof en staken het bij hun vertrek in brand. Pas rond 925 hield het plunderen op."@nl .
id:block_vmk_3_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_vikingen .

# 4. Keizerstad: rijksdagen & Theophanu
id:seg_vmk_4 a nmg:Segment ; nmg:order 4 ; nmg:tickLabel "Keizerstad: rijksdagen & Theophanu" ;
    nmg:mapState id:map_vmk_4 ; nmg:hasBlock id:block_vmk_4_1 , id:block_vmk_4_2 .
id:map_vmk_4 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ;
    nmg:focusPlace id:valkhof .
id:block_vmk_4_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "Onder de Ottoonse en Salische keizers werd het Valkhof een geliefde verblijfplaats: hier werden rijksdagen gehouden (949, 996) en in 991 stierf keizerin Theophanu, moeder van Otto III, in de palts. Aan deze keizerlijke band dankt Nijmegen zijn bijnaam Keizerstad."@nl .
id:block_vmk_4_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_keizerstad .

# 5. De palts verwoest
id:seg_vmk_5 a nmg:Segment ; nmg:order 5 ; nmg:tickLabel "De palts verwoest" ;
    nmg:mapState id:map_vmk_5 ; nmg:hasBlock id:block_vmk_5_1 , id:block_vmk_5_2 .
id:map_vmk_5 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ;
    nmg:focusPlace id:valkhof .
id:block_vmk_5_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "In 1047 ging de palts in vlammen op: hertog Godfried met de Baard verwoestte haar tijdens zijn opstand tegen keizer Hendrik III. De keizerlijke burcht lag daarna in puin — tot Barbarossa haar een eeuw later liet herbouwen."@nl .
id:block_vmk_5_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_palts1047 .

# 6. Barbarossa's Valkhofburcht
id:seg_vmk_6 a nmg:Segment ; nmg:order 6 ; nmg:tickLabel "Barbarossa's Valkhofburcht" ;
    nmg:mapState id:map_vmk_6 ; nmg:hasBlock id:block_vmk_6_1 , id:block_vmk_6_2 .
id:map_vmk_6 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ;
    nmg:focusPlace id:valkhof .
id:block_vmk_6_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "Keizer Frederik Barbarossa liet de palts omstreeks 1155 herbouwen tot een echte burcht. In de luwte van het Valkhof groeit aan de Waal de middeleeuwse stad — het vervolg van dit verhaal."@nl .
id:block_vmk_6_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_barbarossa .

# --- Thread 2: De stad aan de Waal ---

# 7. Rond het Valkhof (no pin — growth only)
id:seg_vmk_7 a nmg:Segment ; nmg:order 7 ; nmg:tickLabel "Rond het Valkhof" ;
    nmg:mapState id:map_vmk_7 ; nmg:hasBlock id:block_vmk_7_1 .
id:map_vmk_7 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ; nmg:overlayLevel 1230 ;
    nmg:focusPlace id:grote_markt , id:valkhof .
id:block_vmk_7_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "In 1184 worden de inwoners — de cives — voor het eerst genoemd; het zwaartepunt verschuift dan van het Valkhof westwaarts, naar de markt aan de Waal. Voor 1230 ligt de bebouwing nog dicht tegen het Valkhof: de kiem van de middeleeuwse stad."@nl .

# 8. Stadsrechten
id:seg_vmk_8 a nmg:Segment ; nmg:order 8 ; nmg:tickLabel "Stadsrechten" ;
    nmg:mapState id:map_vmk_8 ; nmg:hasBlock id:block_vmk_8_1 , id:block_vmk_8_2 .
id:map_vmk_8 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ; nmg:overlayLevel 1230 ;
    nmg:focusPlace id:grote_markt .
id:block_vmk_8_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "Op 31 augustus 1230 verleende rooms-koning Hendrik (VII) Nijmegen stadsrechten naar het voorbeeld van Aken. Als vrije rijksstad kreeg de stad een eigen bestuur en zegel — de status die haar bijnaam Keizerstad bekrachtigde."@nl .
id:block_vmk_8_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_stadsrechten .

# 9. Verpand aan Gelre
id:seg_vmk_9 a nmg:Segment ; nmg:order 9 ; nmg:tickLabel "Verpand aan Gelre" ;
    nmg:mapState id:map_vmk_9 ; nmg:hasBlock id:block_vmk_9_1 , id:block_vmk_9_2 .
id:map_vmk_9 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ; nmg:overlayLevel 1230 ;
    nmg:focusPlace id:valkhof .
id:block_vmk_9_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "In 1247 verpandde rooms-koning Willem II het Rijk van Nijmegen — stad én burcht — aan de graaf van Gelre. De pandsom werd nooit afgelost; sindsdien hoort Nijmegen bij Gelre en niet meer rechtstreeks bij het keizerrijk."@nl .
id:block_vmk_9_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_gelre .

# 10. Sint-Steven & de Maria-Omdracht
id:seg_vmk_10 a nmg:Segment ; nmg:order 10 ; nmg:tickLabel "Sint-Steven & de Maria-Omdracht" ;
    nmg:mapState id:map_vmk_10 ; nmg:hasBlock id:block_vmk_10_1 , id:block_vmk_10_2 .
id:map_vmk_10 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ; nmg:overlayLevel 1230 ;
    nmg:focusPlace id:sint_stevenskerk .
id:block_vmk_10_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "De Sint-Stevenskerk, de middeleeuwse hoofdkerk, werd in 1272 gewijd — naar verluidt door Albertus Magnus. Eromheen ontstond de Maria-Omdracht, een processie die het stadsleven eeuwenlang zou kleuren."@nl .
id:block_vmk_10_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_sintsteven .

# 11. Pest & Jodenvervolging
id:seg_vmk_11 a nmg:Segment ; nmg:order 11 ; nmg:tickLabel "Pest & Jodenvervolging" ;
    nmg:mapState id:map_vmk_11 ; nmg:hasBlock id:block_vmk_11_1 , id:block_vmk_11_2 .
id:map_vmk_11 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ; nmg:overlayLevel 1400 ;
    nmg:focusPlace id:marienburg .
id:block_vmk_11_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "De pest van 1349 trof ook Nijmegen — en werd, zoals in veel Rijnsteden, gevolgd door een vervolging van de joodse gemeenschap, destijds de grootste van de Lage Landen. De donkere keerzijde van de bloeiende stad."@nl .
id:block_vmk_11_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_pest .

# 12. De stad breidt uit (no pin — growth only)
id:seg_vmk_12 a nmg:Segment ; nmg:order 12 ; nmg:tickLabel "De stad breidt uit" ;
    nmg:mapState id:map_vmk_12 ; nmg:hasBlock id:block_vmk_12_1 .
id:map_vmk_12 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ; nmg:overlayLevel 1400 ;
    nmg:focusPlace id:grote_markt , id:valkhof .
id:block_vmk_12_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "Tussen 1250 en 1400 groeit Nijmegen binnen de stadsmuren tot een welvarende handelsstad."@nl .

# 13. Hanzestad (pin + arrows)
id:seg_vmk_13 a nmg:Segment ; nmg:order 13 ; nmg:tickLabel "Hanzestad" ;
    nmg:mapState id:map_vmk_13 ; nmg:hasBlock id:block_vmk_13_1 , id:block_vmk_13_2 .
id:map_vmk_13 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ; nmg:overlayLevel 1400 ;
    nmg:focusPlace id:waalkade ;
    nmg:arrow id:arrow_vmk_13a , id:arrow_vmk_13b .
id:arrow_vmk_13a a nmg:Arrow ; nmg:arrowFrom id:waalkade ; nmg:arrowTo id:keulen ;
    nmg:arrowLabel "naar Keulen" ; nmg:arrowCurve 0.14 .
id:arrow_vmk_13b a nmg:Arrow ; nmg:arrowFrom id:waalkade ; nmg:arrowTo id:holland ;
    nmg:arrowLabel "naar Holland & de zee" ; nmg:arrowCurve -0.14 .
id:block_vmk_13_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "In 1402 werd Nijmegen Hanzestad. Vanaf de Waalkade voeren koggen stroomopwaarts naar Keulen en stroomafwaarts naar Holland en de zee; de stad werd het regionale hoofd van het Keulse Hanzekwartier."@nl .
id:block_vmk_13_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_hanze .

# 14. Volgroeide middeleeuwse stad (no pin — growth only)
id:seg_vmk_14 a nmg:Segment ; nmg:order 14 ; nmg:tickLabel "Volgroeide middeleeuwse stad" ;
    nmg:mapState id:map_vmk_14 ; nmg:hasBlock id:block_vmk_14_1 .
id:map_vmk_14 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ; nmg:overlayLevel 1525 ;
    nmg:focusPlace id:grote_markt , id:valkhof .
id:block_vmk_14_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "Rond 1525 is de ommuurde stad zo goed als vol; verdere groei moet wachten tot de muren vallen."@nl .

# --- Thread 3: Stad van naam ---

# 15. De gebroeders van Limburg
id:seg_vmk_15 a nmg:Segment ; nmg:order 15 ; nmg:tickLabel "De gebroeders van Limburg" ;
    nmg:mapState id:map_vmk_15 ; nmg:hasBlock id:block_vmk_15_1 , id:block_vmk_15_2 .
id:map_vmk_15 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ;
    nmg:focusPlace id:stevenskerkhof .
id:block_vmk_15_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "Rond 1385 werden in Nijmegen de broers Herman, Paul en Johan van Limburg geboren — de beroemdste miniatuurschilders van hun tijd. Voor de Franse hertog Jean de Berry verluchtten zij de Très Riches Heures, het rijkst versierde getijdenboek van de middeleeuwen. Alle drie stierven ze jong, vermoedelijk in 1416 aan de pest."@nl .
id:block_vmk_15_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_limburg .

# 16. Mariken van Nieumeghen
id:seg_vmk_16 a nmg:Segment ; nmg:order 16 ; nmg:tickLabel "Mariken van Nieumeghen" ;
    nmg:mapState id:map_vmk_16 ; nmg:hasBlock id:block_vmk_16_1 , id:block_vmk_16_2 .
id:map_vmk_16 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ;
    nmg:focusPlace id:grote_markt .
id:block_vmk_16_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "Het rederijkersspel Mariken van Nieumeghen, gedrukt rond 1515, speelt zich af in en rond Nijmegen. Het vertelt hoe het meisje Mariken zeven jaar lang met de duivel Moenen door de wereld trekt, tot een mirakelspel haar van haar zonden verlost. Een hoogtepunt van de Middelnederlandse letterkunde — vandaag staat Mariken in brons op de Grote Markt."@nl .
id:block_vmk_16_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_mariken .

# 17. Petrus Canisius
id:seg_vmk_17 a nmg:Segment ; nmg:order 17 ; nmg:tickLabel "Petrus Canisius" ;
    nmg:mapState id:map_vmk_17 ; nmg:hasBlock id:block_vmk_17_1 , id:block_vmk_17_2 .
id:map_vmk_17 a nmg:MapState ; nmg:baseYear "1557"^^xsd:gYear ;
    nmg:focusPlace id:broerstraat .
id:block_vmk_17_1 a nmg:NarrativeBlock ; nmg:order 1 ;
    schema:text "Op 8 mei 1521 werd in de Broerstraat Petrus Canisius geboren. Als jezuïet werd hij de drijvende kracht achter de katholieke Contrareformatie in Duitstalig Europa; zijn catechismus werd eeuwenlang herdrukt. In 1925 werd hij heilig verklaard en tot kerkleraar uitgeroepen — de bekendste zoon van de stad."@nl .
id:block_vmk_17_2 a nmg:ImageBlock ; nmg:order 2 ; nmg:references id:src_vmk_canisius .
