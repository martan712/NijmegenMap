id:block_marketgarden_1 a nmg:NarrativeBlock ;
    nmg:order 1 ;
    schema:text "Op 17 september 1944 begon Operatie Market Garden. Boven Groesbeek en de heuvels ten zuiden van Nijmegen daalden duizenden parachutisten neer; de Amerikaanse 82nd Airborne kreeg de opdracht de Waalbrug te veroveren. Voor de Nijmegenaren leek de bevrijding ineens nabij."@nl ;
    nmg:about id:market_garden ;
    nmg:cites id:src_marketgarden .
