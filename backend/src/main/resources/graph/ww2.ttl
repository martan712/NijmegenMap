############################  PLACES  ############################
id:grote_markt a nmg:Place ; rdfs:label "Grote Markt"@nl ; nmg:lat 51.8475 ; nmg:long 5.8649 .
id:binnenstad a nmg:Place ; rdfs:label "Verwoeste binnenstad"@nl ; nmg:lat 51.8478 ; nmg:long 5.8635 .
id:annastraat a nmg:Place ; rdfs:label "Sint Annastraat"@nl ; nmg:lat 51.838 ; nmg:long 5.846 .
id:nieuwe_synagoge a nmg:Building ; rdfs:label "Nieuwe Synagoge"@nl ; nmg:lat 51.8466 ; nmg:long 5.8612 .
id:landingszone a nmg:Place ; rdfs:label "Landingszone (Groesbeekse heuvels)"@nl ; nmg:lat 51.812 ; nmg:long 5.905 .
id:waalbrug a nmg:Bridge ; rdfs:label "Waalbrug"@nl ; nmg:lat 51.857 ; nmg:long 5.866 ; owl:sameAs wd:Q1798831 .
id:elektriciteitscentrale a nmg:Building ; rdfs:label "PGEM-elektriciteitscentrale (zuidoever)"@nl ; nmg:lat 51.8548 ; nmg:long 5.8495 .
id:noordoever a nmg:Place ; rdfs:label "Noordoever (landingsplek)"@nl ; nmg:lat 51.8608 ; nmg:long 5.852 .

############################  ACTORS  ############################
id:unit_504_pir a nmg:MilitaryUnit ;
    rdfs:label "504th Parachute Infantry Regiment, 82nd Airborne"@en ; owl:sameAs wd:Q7727349 .
id:person_dozy a nmg:Person ; rdfs:label "Petronella Dozy"@nl .

############################  EVENTS  ############################
id:bezetting a nmg:Event ; rdfs:label "Bezetting van Nijmegen"@nl ;
    nmg:startDate "1940-05-10"^^xsd:date ; nmg:occurredAt id:annastraat .
id:deportatie a nmg:Event ; rdfs:label "Deportatie van de joodse gemeenschap"@nl ;
    nmg:startDate "1942-11-17"^^xsd:date ; nmg:occurredAt id:nieuwe_synagoge .
id:bombardement a nmg:Event ; rdfs:label "Het vergissingsbombardement"@nl ;
    nmg:startDate "1944-02-22"^^xsd:date ; nmg:occurredAt id:binnenstad .
id:market_garden a nmg:Event ; rdfs:label "Operatie Market Garden"@nl ;
    nmg:startDate "1944-09-17"^^xsd:date ; owl:sameAs wd:Q156721 ;
    nmg:occurredAt id:landingszone .
id:de_waaloversteek a nmg:Event ; rdfs:label "De Waaloversteek"@nl ;
    nmg:startDate "1944-09-20"^^xsd:date ; nmg:partOf id:market_garden ;
    nmg:occurredAt id:elektriciteitscentrale , id:noordoever , id:waalbrug ;
    nmg:hadParticipant id:unit_504_pir .
id:brug_genomen a nmg:Event ; rdfs:label "De brug genomen"@nl ;
    nmg:startDate "1944-09-20"^^xsd:date ; nmg:partOf id:market_garden ; nmg:occurredAt id:waalbrug .
id:frontstad a nmg:Event ; rdfs:label "Frontstad"@nl ;
    nmg:startDate "1944-10-15"^^xsd:date ; nmg:occurredAt id:annastraat .
id:bevrijding a nmg:Event ; rdfs:label "Bevrijding & nasleep"@nl ;
    nmg:startDate "1945-04-01"^^xsd:date ; nmg:occurredAt id:grote_markt .

