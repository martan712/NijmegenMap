    nmg:heritageCategory "grafveld" ;
    nmg:focusPlace id:waterstraat .
id:block_pre_2_1 a nmg:NarrativeBlock ;
    nmg:order 1 ;
    schema:text "Rond 50 v.Chr. vestigden zich de eerste Bataven in het gebied; de Waterstraat in de benedenstad gaat terug op een van de oudste wegen van Nederland. Wanneer kort daarna de Romeinen arriveren, treffen ze hier dus al bewoning aan — het begin van Romeins Nijmegen."@nl .
id:block_pre_2_2 a nmg:ImageBlock ;
    nmg:order 2 ;
    nmg:references id:src_bataven .
