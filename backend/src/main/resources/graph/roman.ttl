id:block_pre_1_1 a nmg:NarrativeBlock ;
    nmg:order 1 ;
    schema:text "Al lang voor de Romeinen woonden hier mensen. In Nijmegen-Oost liggen sporen uit het neolithicum tot de late bronstijd: grafheuvels en urnenvelden. De rivierovergang en de hoge stuwwal maakten deze plek al vroeg aantrekkelijk om te wonen."@nl .
id:block_pre_1_2 a nmg:ImageBlock ;
    nmg:order 2 ;
    nmg:references id:src_grafheuvel .
